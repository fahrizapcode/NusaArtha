# env files – jangan push secret, tapi .env.example boleh
.env
.env.*
!.env.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# database – jangan push file SQLite lokal
prisma/*.db
prisma/*.db-journal
prisma/*.db-shm
prisma/*.db-wal
